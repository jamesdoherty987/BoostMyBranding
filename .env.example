# ============================================================================
# BoostMyBranding — Environment variable template
# ============================================================================
# Copy to `.env` and fill in. Everything with an empty value has a mock/local
# fallback, so the app runs without them — but the feature the var powers
# won't work until it's set.

NODE_ENV=development

# ----- Public URLs --------------------------------------------------------
# In dev each app runs on its own port. In production the web app is the
# entry point and rewrites /portal/*, /dashboard/*, /api/* to their
# upstreams, so the public URLs all share the origin.

APP_URL=http://localhost:3000
PORTAL_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002

# In production on Vercel, override these:
# NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# NEXT_PUBLIC_PORTAL_URL=https://your-domain.com/portal
# NEXT_PUBLIC_DASHBOARD_URL=https://your-domain.com/dashboard
#
# Web app rewrites (required in prod, on the `apps/web` Vercel project):
# PORTAL_UPSTREAM=https://your-portal-deployment.vercel.app
# DASHBOARD_UPSTREAM=https://your-dashboard-deployment.vercel.app
# API_UPSTREAM=https://your-api-deployment.example.com
#
# Next.js basePath for portal + dashboard (prod only):
# PORTAL_BASE_PATH=/portal
# DASHBOARD_BASE_PATH=/dashboard

# ----- Auth (required) ----------------------------------------------------
# Generate a fresh 32-byte hex: openssl rand -hex 32
AUTH_SECRET=

# ----- Database (required) ------------------------------------------------
# Postgres connection string. Neon works out of the box.
# Example: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# ----- Claude AI (optional; mock fallback) --------------------------------
ANTHROPIC_API_KEY=

# ----- fal.ai for hero images (optional; Picsum mock fallback) ------------
FAL_KEY=

# ----- Cloudflare R2 storage (optional; local disk fallback) --------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ----- Stripe (required for paid subscriptions) ---------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOCIAL=
STRIPE_PRICE_SOCIAL_WEBSITE=
STRIPE_PRICE_FULL_AGENCY=

# ----- Vercel API (required for custom domain attach) ---------------------
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# ----- ContentStudio (optional; social publishing) ------------------------
CONTENTSTUDIO_API_KEY=

# ----- Resend (optional; transactional emails) ----------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
