# Copy this to .env and fill in real values for production.
# Every integration below is optional locally — the app runs with mock fallbacks.

NODE_ENV=development

# Public URLs (change to your real domains in production)
APP_URL=http://localhost:3000
PORTAL_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3002

# Auth — generate with: openssl rand -hex 32
AUTH_SECRET=replace-me-with-a-32-char-random-string

# Database (required for real data — see docs/SETUP.md step 2)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/boostmybranding

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# fal.ai (Flux)
FAL_KEY=

# Cloudflare R2 (uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=boostmybranding-uploads
R2_PUBLIC_URL=

# Stripe (subscriptions)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOCIAL=
STRIPE_PRICE_WEBSITE=
STRIPE_PRICE_FULL=

# Resend (email)
RESEND_API_KEY=
FROM_EMAIL=contact@boostmybranding.com

# ContentStudio (publishing)
CONTENTSTUDIO_API_KEY=
CONTENTSTUDIO_WORKSPACE_ID=

# Cron protection
CRON_SECRET=
